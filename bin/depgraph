#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use DTL\Depgraph\Command\DepgraphCommand;
use DTL\Depgraph\Depgraph;
use DTL\Depgraph\DepgraphFactory;
use Symfony\Component\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Output\ConsoleOutput;

$application = new Application();

$output = new ConsoleOutput();
$input = new ArgvInput();

$application->addCommand(new DepgraphCommand(DepgraphFactory::default(offline: false, output: $output->getErrorOutput())));
$application->setDefaultCommand('depgraph');
$application->run($input, $output);
